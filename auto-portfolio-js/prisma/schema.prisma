// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"] // Target for Alpine Linux in Docker
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Config {
  id              Int      @id @default(autoincrement())
  theme           String   @default("dark")
  layoutOrder     String   @default("[]") // JSON array of section names
  resumeUrl       String?
  userImage       String?  // URL for the user's profile image
  bentoData       String?  // JSON for bento grid configuration
  aiMethod        String   @default("official")
  geminiApiKey    String?
  geminiProxyUrl  String?
  geminiProxyKey  String?
  geminiModel     String   @default("gemini-2.0-flash")
  name            String   @default("Sumit Bhagat")
  titles          String   @default("[\"Full-Stack Developer\", \"Crafting Digital Experiences\", \"Building Scalable Solutions\"]")
  email           String   @default("sumitbhagat011@gmail.com")
  githubUrl       String   @default("https://github.com/sumit-bhagat-2004")
  linkedinUrl     String   @default("")
  twitterUrl      String   @default("")
  skillsData      String   @default("[]")
  chatbotPrompt   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  githubId    Int?     @unique // GitHub repository ID
  name        String
  url         String?
  language    String?
  stars       Int      @default(0)
  forks       Int      @default(0)
  watchers    Int      @default(0)
  summary     String?  // Rich text/markdown summary
  tags        String   @default("[]") // JSON array of tags
  visible     Boolean  @default(true)
  featured    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  dateRange   String
  description String?
  category    String   // "education" or "experience"
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, orderIndex])
}


